@model MoviesViewModel
@{
    ViewData["Title"] = "IndexWithViewModel";
}

<h1>IndexWithViewModel</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>


<form asp-action="Filter" method="get">
    <div class="input-group mb-3">
        <input type="text"
               class="form-control"
               name="title"
               placeholder="Search title" />

        <select class="form-select"
                name="genre"
                asp-items="Model.Genres">
            <option value="">Please select genre</option>
        </select>

        <button type="submit" class="btn btn-primary">
            Search
        </button>
    </div>
</form>

<partial name="_MovieListPartial" model="Model.Movies" />